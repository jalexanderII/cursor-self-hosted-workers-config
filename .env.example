# AWS account and region used by Make targets.
AWS_PROFILE=default
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# Shared names. Keep these stable once deployed.
DEPLOYMENT_NAME=cursor-workers
ENVIRONMENT=prod
ECR_REPOSITORY_NAME=cursor-self-hosted-worker
WORKER_IMAGE_TAG=latest
WORKER_PLATFORM=linux/amd64

# Cursor worker settings.
CURSOR_WORKER_POOL_NAME=default
CURSOR_WORKER_IDLE_RELEASE_TIMEOUT=900
CURSOR_API_SECRET_ID=cursor/self-hosted-workers/cursor-api-key
GITHUB_PAT_SECRET_ID=cursor/self-hosted-workers/github-pat

# Set these only in your local .env or shell. Do not commit secret values.
CURSOR_API_KEY=
GITHUB_PAT=

# Repository workers should clone.
REPO_SLUG=YOUR_ORG/YOUR_REPO
REPO_BRANCH=main
GITHUB_HOST=github.com

# EC2 ASG defaults.
EC2_TF_DIR=terraform/examples/ec2-asg
EC2_VPC_ID=
EC2_SUBNET_IDS=
EC2_INSTANCE_TYPE=m6i.xlarge
EC2_ASG_MIN_SIZE=1
EC2_ASG_DESIRED_CAPACITY=1
EC2_ASG_MAX_SIZE=3
EC2_WORKER_SLOTS_PER_INSTANCE=5

# Kubernetes/EKS defaults.
EKS_CLUSTER_TF_DIR=terraform/examples/eks-new-cluster
EKS_WORKERS_TF_DIR=terraform/examples/eks-existing-cluster
EKS_CLUSTER_NAME=cursor-workers
K8S_NAMESPACE=cursord
WORKER_DEPLOYMENT_NAME=cursor-workers
WORKER_READY_REPLICAS=3
CURSOR_API_KEY_SECRET_NAME=cursor-workers-api-key
GITHUB_PAT_SECRET_NAME=cursor-workers-github

# Terraform variables consumed by the example roots. Override in .env or a
# terraform.tfvars file when your AWS baseline differs from these defaults.
TF_VAR_aws_region=${AWS_REGION}
TF_VAR_aws_profile=${AWS_PROFILE}
TF_VAR_deployment_name=${DEPLOYMENT_NAME}
TF_VAR_environment=${ENVIRONMENT}
TF_VAR_ecr_repository_name=${ECR_REPOSITORY_NAME}
TF_VAR_worker_image_tag=${WORKER_IMAGE_TAG}
TF_VAR_cursor_api_secret_name=${CURSOR_API_SECRET_ID}
TF_VAR_github_pat_secret_name=${GITHUB_PAT_SECRET_ID}
TF_VAR_repo_slug=${REPO_SLUG}
TF_VAR_repo_branch=${REPO_BRANCH}
TF_VAR_worker_pool_name=${CURSOR_WORKER_POOL_NAME}
TF_VAR_worker_idle_release_timeout=${CURSOR_WORKER_IDLE_RELEASE_TIMEOUT}
TF_VAR_ec2_instance_type=${EC2_INSTANCE_TYPE}
TF_VAR_ec2_asg_min_size=${EC2_ASG_MIN_SIZE}
TF_VAR_ec2_asg_desired_capacity=${EC2_ASG_DESIRED_CAPACITY}
TF_VAR_ec2_asg_max_size=${EC2_ASG_MAX_SIZE}
TF_VAR_ec2_worker_slots_per_instance=${EC2_WORKER_SLOTS_PER_INSTANCE}
TF_VAR_eks_cluster_name=${EKS_CLUSTER_NAME}
TF_VAR_k8s_namespace=${K8S_NAMESPACE}
TF_VAR_worker_deployment_name=${WORKER_DEPLOYMENT_NAME}
TF_VAR_worker_ready_replicas=${WORKER_READY_REPLICAS}
TF_VAR_cursor_api_key_secret_name=${CURSOR_API_KEY_SECRET_NAME}
TF_VAR_github_pat_secret_name_k8s=${GITHUB_PAT_SECRET_NAME}

# Set these as HCL values when using non-default networking, for example:
# TF_VAR_vpc_id=vpc-0123456789abcdef0
# TF_VAR_subnet_ids=["subnet-aaa","subnet-bbb","subnet-ccc"]
