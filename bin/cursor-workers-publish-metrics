#!/usr/bin/env bash
set -euo pipefail

# Publish local worker health metrics to CloudWatch.
#
# Metrics are derived from this instance's manifest and localhost /readyz
# endpoints, so they represent this EC2 fleet rather than the whole Cursor team.
set -a
. /etc/cursor-workers/env
set +a

MANIFEST="${CURSOR_WORKERS_MANIFEST:-/etc/cursor-workers/workers.json}"
METRICS_NAMESPACE="${CURSOR_METRICS_NAMESPACE:-Cursor/SelfHostedWorkers}"

# IMDSv2 is used to attach InstanceId as a metric dimension.
TOKEN="$(curl -sX PUT "http://169.254.169.254/latest/api/token" \
  -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")"

INSTANCE_ID="$(curl -sH "X-aws-ec2-metadata-token: $TOKEN" \
  "http://169.254.169.254/latest/meta-data/instance-id")"

REPO="$(jq -r '.repo' "$MANIFEST")"

total=0
ready=0
claimed=0
failed=0

while read -r worker; do
  id="$(echo "$worker" | jq -r '.id')"
  port="$(echo "$worker" | jq -r '.managementPort')"
  service="cursor-worker-${id}.service"

  total=$((total + 1))

  # systemd state catches failed worker processes even if the management port is
  # not responding.
  if ! systemctl is-active --quiet "$service"; then
    failed=$((failed + 1))
    continue
  fi

  body="$(curl -s --max-time 2 "http://127.0.0.1:${port}/readyz" || true)"

  # ReadyWorkers are idle and immediately available for a new agent session.
  if echo "$body" | jq -e '.connected == true and .claimed == false and .status == "ok"' >/dev/null 2>&1; then
    ready=$((ready + 1))
  fi

  # ClaimedWorkers include active sessions and workers held for follow-up during
  # the idle-release timeout window.
  if echo "$body" | jq -e '.claimed == true' >/dev/null 2>&1; then
    claimed=$((claimed + 1))
  fi
done < <(jq -c '.workers[]' "$MANIFEST")

# Emit separate metric names so CloudWatch alarms and dashboards can be built
# without parsing dimensions or logs.
for metric in TotalWorkers ReadyWorkers ClaimedWorkers FailedWorkerServices; do
  case "$metric" in
    TotalWorkers) value="$total" ;;
    ReadyWorkers) value="$ready" ;;
    ClaimedWorkers) value="$claimed" ;;
    FailedWorkerServices) value="$failed" ;;
  esac

  aws cloudwatch put-metric-data \
    --region "$AWS_REGION" \
    --namespace "$METRICS_NAMESPACE" \
    --metric-name "$metric" \
    --dimensions "InstanceId=${INSTANCE_ID},Repo=${REPO}" \
    --unit Count \
    --value "$value"
done
