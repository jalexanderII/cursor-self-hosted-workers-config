#!/usr/bin/env bash
set -euo pipefail

# Git credential helper used by git clone/fetch/push.
#
# Git calls this script with "get" and sends protocol/host fields on stdin.
# For the configured GitHub host, return a username/password pair where the
# password is fetched just-in-time from AWS Secrets Manager. This avoids storing
# the GitHub PAT in clone URLs, systemd units, shell history, or ~/.git-credentials.
op="${1:-get}"

case "$op" in
  get)
    host=""

    # Parse git-credential input. We only need "host" to decide whether this
    # helper should answer the request.
    while IFS='=' read -r key value; do
      if [ "$key" = "host" ]; then
        host="$value"
      fi
    done

    # Keep all deployment-specific values in one root-managed env file.
    set -a
    # shellcheck source=/dev/null
    . /etc/cursor-workers/env
    set +a
    github_host="${GITHUB_HOST:-github.com}"

    # Return no credentials for unrelated hosts so other helpers can handle them.
    if [ "$host" != "$github_host" ]; then
      exit 0
    fi

    # SecretString is expected to be the raw PAT, not a JSON object.
    token="$(aws secretsmanager get-secret-value \
      --region "$AWS_REGION" \
      --secret-id "$GITHUB_PAT_SECRET_ID" \
      --query SecretString \
      --output text)"

    printf 'username=x-access-token\n'
    printf 'password=%s\n' "$token"
    ;;
  store|erase)
    # Credentials are owned by Secrets Manager; never persist or erase locally.
    exit 0
    ;;
  *)
    exit 0
    ;;
esac
