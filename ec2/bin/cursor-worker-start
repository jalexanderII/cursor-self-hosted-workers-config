#!/usr/bin/env bash
set -euo pipefail

# Start exactly one Cursor pool worker.
#
# systemd injects CURSOR_WORKER_* for the specific worker slot. Before the
# worker registers as available, this script resets its git workspace to the
# configured remote branch so a completed session cannot leak dirty files into
# the next session.
: "${CURSOR_WORKER_DIR:?missing CURSOR_WORKER_DIR}"
: "${CURSOR_WORKER_NAME:?missing CURSOR_WORKER_NAME}"
: "${CURSOR_WORKER_PORT:?missing CURSOR_WORKER_PORT}"

# Shared deployment configuration and secret IDs live here.
set -a
. /etc/cursor-workers/env
set +a

MANIFEST="${CURSOR_WORKERS_MANIFEST:-/etc/cursor-workers/workers.json}"
BRANCH="$(jq -r '.branch' "$MANIFEST")"
AGENT_BIN="${CURSOR_AGENT_BIN:-/home/ubuntu/.local/bin/agent}"
LABELS_FILE="${CURSOR_WORKERS_LABELS_FILE:-/etc/cursor-workers/labels.json}"
LOCK_FILE="${CURSOR_WORKERS_GIT_CLEAN_LOCK:-/tmp/cursor-worker-git-cleanup.lock}"
CLEAN_MODE="${CURSOR_WORKER_CLEAN_MODE:-normal}"

echo "Preparing clean worker workspace: ${CURSOR_WORKER_DIR} -> origin/${BRANCH}"

# Worktrees share git metadata, so serialize fetch/reset cleanup across workers.
# Without the lock, multiple workers starting together can contend on git's
# shared object database and worktree metadata.
(
  flock -x 200

  git -C "$CURSOR_WORKER_DIR" fetch origin --prune
  git -C "$CURSOR_WORKER_DIR" reset --hard "origin/${BRANCH}"

  # "normal" removes untracked files while preserving ignored caches such as
  # node_modules. "full" is more sterile but slower because it removes ignored
  # files too. "none" is useful only for debugging.
  case "$CLEAN_MODE" in
    normal)
      git -C "$CURSOR_WORKER_DIR" clean -fd
      ;;
    full)
      git -C "$CURSOR_WORKER_DIR" clean -fdx
      ;;
    none)
      ;;
    *)
      echo "Invalid CURSOR_WORKER_CLEAN_MODE: ${CLEAN_MODE}" >&2
      exit 1
      ;;
  esac
) 200>"$LOCK_FILE"

# Optional repo-local environment file hydration.
#
# Design:
# - Each AWS Secrets Manager secret stores one complete file as raw SecretString
#   (for example an existing 300-line .env file pasted/uploaded as-is).
# - CURSOR_REPO_ENV_FILES points to a root-owned mapping file with lines shaped:
#     repo/relative/target secret/id/whose/SecretString/is/the/file
# - Inject after git cleanup because `git clean -fd` removes untracked .env
#   files on every worker restart.
# - Inject before `agent worker start` so claimed worker sessions see the
#   files from the beginning.
# This avoids JSON escaping/newline conversion and scales to large enterprise
# env files without reformatting.
inject_repo_env_files() {
  local mapping_file="${CURSOR_REPO_ENV_FILES:-}"
  if [ -z "$mapping_file" ]; then
    return 0
  fi

  if [ ! -f "$mapping_file" ]; then
    echo "CURSOR_REPO_ENV_FILES points to missing file: ${mapping_file}" >&2
    exit 1
  fi

  echo "Injecting repo env files from ${mapping_file}"

  local target_rel secret_id extra target_dir target
  while read -r target_rel secret_id extra; do
    if [ -z "${target_rel:-}" ] || [[ "$target_rel" == \#* ]]; then
      continue
    fi
    if [ -z "${secret_id:-}" ]; then
      echo "Missing secret id for repo env target: ${target_rel}" >&2
      exit 1
    fi
    if [ -n "${extra:-}" ]; then
      echo "Invalid repo env mapping line for ${target_rel}: expected exactly two fields" >&2
      exit 1
    fi
    if [[ "$target_rel" == /* ]] || [[ "$target_rel" == *".."* ]] || [[ "$target_rel" == */ ]]; then
      echo "Invalid repo env target path: ${target_rel}" >&2
      exit 1
    fi

    target="${CURSOR_WORKER_DIR}/${target_rel}"
    target_dir="$(dirname "$target")"
    mkdir -p "$target_dir"
    if ! aws secretsmanager get-secret-value \
      --region "$AWS_REGION" \
      --secret-id "$secret_id" \
      --query SecretString \
      --output text >"$target"; then
      rm -f "$target"
      echo "Failed to fetch repo env secret for ${target_rel}: ${secret_id}" >&2
      exit 1
    fi
    chmod 600 "$target"
  done < "$mapping_file"
}

inject_repo_env_files

# Fetch the service account API key at process start. The key is never written
# to disk by this script.
CURSOR_API_KEY="$(aws secretsmanager get-secret-value \
  --region "$AWS_REGION" \
  --secret-id "$CURSOR_API_SECRET_ID" \
  --query SecretString \
  --output text)"

export CURSOR_API_KEY

# Keep the command in an array so optional flags can be appended safely.
cmd=(
  "$AGENT_BIN" worker start
  --pool \
  --pool-name "$CURSOR_WORKER_POOL_NAME" \
  --worker-dir "$CURSOR_WORKER_DIR" \
  --management-addr "127.0.0.1:${CURSOR_WORKER_PORT}" \
  --idle-release-timeout "$CURSOR_WORKER_IDLE_RELEASE_TIMEOUT" \
  --name "$CURSOR_WORKER_NAME"
)

# Labels are optional routing/metadata. They are not a security boundary.
if [ -f "$LABELS_FILE" ]; then
  cmd+=(--labels-file "$LABELS_FILE")
fi

exec "${cmd[@]}"
